# Application
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=student_management_system

# Or use connection URL directly (uncomment if preferred)
# DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/student_management_system

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Security
BCRYPT_SALT_ROUNDS=10

# Initial Admin User (used by seed:admin script)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234
ADMIN_FULL_NAME=مدير النظام

# API Configuration
API_PREFIX=/api
API_VERSION=v1
